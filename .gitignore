# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# guestbook JSON store (runtime data, seeded on demand)
/.data/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real secrets stay out, but keep the (secret-free) template in
.env*
!.env.local.example
!.env.example

# Environment & Secrets (CRITICAL — never commit)
.env
.env.*
!.env.example
.env.local
.env.*.local
.mise.toml
deploy/.env
node-compile-cache

# Infisical & MCP (contains API keys)
.infisical.json
.mcp.json

# backup archives / snapshots — never commit these
*.tar.gz
*.tgz
*.zip

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.claude/
.agents/
CLAUDE.md
